# API
API_BASE_URL=http://10.215.39.31:22205
# Cole aqui o Bearer token copiado do browser (F12 > aba token > Resposta > access_token)
API_TOKEN=eyJra...

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=noc
MYSQL_USER=user
MYSQL_PASSWORD=senha

# Sync
PAGE_SIZE=500
BATCH_SIZE=500
INITIAL_DATE=2025-01-01T00:00
LOG_LEVEL=INFO

# Sincronização bidirecional
# Quantos dias de histórico buscar por execução (backward sync)
BACKWARD_WINDOW_DAYS=7
# Parar o forward sync quando esta fração de uma página já existir no DB (0.9 = 90%)
DUPLICATE_THRESHOLD=0.9
# Segundos de espera entre ciclos quando o histórico está completo (padrão: 300 = 5 min)
SYNC_INTERVAL=300
